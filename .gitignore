# ---- R session & build artefacts ----
.Rhistory
.Rapp.history
.RData
.RDataTmp
.Ruserdata
*-Ex.R
/*.tar.gz
/*.Rcheck/
.Rproj.user/
*_cache/
/cache/
*.utf8.md
*.knit.md

# ---- Environment ----
.Renviron
.Rprofile.local
rsconnect/

# ---- renv: keep settings & lockfile, ignore the local library ----
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/staging/

# ---- Quarto / knitr build artefacts ----
.quarto/
*_files/
*.html
*.pdf
# But DO commit everything under renders/ — that's the published website and
# the compiled manuscript, the whole point of the folder. (LaTeX intermediates
# like .aux/.log are re-ignored by the block further down, even under renders/.)
!renders/**

# ---- Sensitive data ----
# Everything under data/raw/ and data/processed/ is private by default.
# Only the README and .gitkeep are tracked.
data/raw/**
data/processed/**
!data/raw/README.md
!data/raw/.gitkeep
!data/processed/README.md
!data/processed/.gitkeep

# Belt & suspenders: never commit common data formats anywhere,
# even if someone drops one into a non-data folder by mistake.
*.csv
*.tsv
*.sav
*.dta
*.xls
*.xlsx
*.parquet
*.feather
*.rds
*.RData
*.sqlite
*.sqlite3
*.db

# ...except in data/mock/ (synthetic, safe to share) and any explicit overrides:
!data/mock/**

# ---- LaTeX intermediates ----
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.synctex.gz
*.lof
*.lot

# ---- OS / editor noise ----
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# ---- Workshop context (private notes only, never the repo template) ----
workshop_info/
